# Pinned external dependency revisions for reproducible Minotaur builds.
#
# LLVM is pinned to the commit behind the upstream 21.1.7 release tag
# (llvmorg-21.1.7).
MINOTAUR_LLVM_REF=292dc2b86f66e39f4b85ec8b185fd8b60f5213ce
#
# Alive2 is pinned to the newest upstream commit we validated against
# LLVM 21.1.7 as of 2026-03-16.
MINOTAUR_ALIVE2_REF=f9ad3cb48a926f456b79e22e73b91cff03fc7b81
#
# Z3 is pinned to the upstream release tag currently used by Minotaur.
MINOTAUR_Z3_REF=z3-4.15.4

import argparse
import os
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass

sys.path.insert(0, "@PROJECT_SOURCE_DIR@/scripts")
from minotaur_redis import RedisClient, RedisError


def default_nprocs():
    count = os.cpu_count()
    if count is None:
        return 40
    return max(1, count - 2)


def usage(default_n):
    print(
        "Options:\n"
        f"  -n                        number of CPUs to use (default={default_n})\n"
        "  -tag                      add this tag to cache entries, and skip entries with it\n"
        "  -separate-files           put each invocation's output into its own output file\n"
        "  -souper-debug-level       accepted for compatibility\n"
        "  -verbose                  print extra output\n"
        "  -unix                     talk to Redis using UNIX domain sockets"
    )
    raise SystemExit(-1)


DEFAULT_NPROCS = default_nprocs()

parser = argparse.ArgumentParser(add_help=False)
parser.add_argument("-n", type=int, default=DEFAULT_NPROCS)
parser.add_argument("-tag", default="x")
parser.add_argument("-verbose", action="store_true")
parser.add_argument("-unix", action="store_true")
parser.add_argument("-separate-files", action="store_true")
parser.add_argument("-souper-debug-level", type=int, default=0)
try:
    ARGS, EXTRA = parser.parse_known_args()
except SystemExit:
    usage(DEFAULT_NPROCS)

if EXTRA:
    usage(DEFAULT_NPROCS)

REDIS_PORT = 6379
CACHE_VERSION = os.environ.get("MINOTAUR_CACHE_VERSION", "2")
TIMEOUT_SEC = int(os.environ.get("MINOTAUR_CACHE_INFER_TIMEOUT_SEC", "600"))
MINOTAUR = "@CMAKE_BINARY_DIR@/infer-cut.sh"
CACHE_SOCK = "@CMAKE_BINARY_DIR@/cache.sock"


def connect_redis():
    if ARGS.unix:
        return RedisClient(sock_path=CACHE_SOCK)
    return RedisClient(server=("localhost", REDIS_PORT))


def mark_timeout(opt):
    client = connect_redis()
    try:
        client.hset(
            opt,
            {
                "rewrite": "<timeout>",
                "timestamp": int(time.time()),
                "version": CACHE_VERSION,
            },
        )
    finally:
        client.close()


@dataclass
class Worker:
    opt: str
    tmp_path: str
    out_path: str
    input_handle: object
    output_handle: object
    proc: subprocess.Popen


class StatusPrinter:
    def __init__(self, total):
        self.total = max(total, 1)
        self.count = 0
        self.last_pct = 0

    def tick(self):
        print(".", end="", flush=True)
        self.count += 1
        pct = int(100.0 * self.count / self.total)
        if pct > self.last_pct:
            self.last_pct = pct
            print(f"{pct} %")


def launch_worker(opt):
    with tempfile.NamedTemporaryFile(mode="w", encoding="utf-8", delete=False) as tmp:
        tmp.write(opt)
        tmp.flush()
        tmp_path = tmp.name

    cmd = [MINOTAUR, "-S"]
    if TIMEOUT_SEC > 0:
        cmd = [
            "timeout",
            "--signal=TERM",
            "--kill-after=10s",
            f"{TIMEOUT_SEC}s",
        ] + cmd

    input_handle = open(tmp_path, "rb")
    output_handle = tempfile.NamedTemporaryFile(
        mode="wb",
        prefix="tmp_",
        suffix=".log",
        delete=False,
    )
    proc = subprocess.Popen(
        cmd,
        stdin=input_handle,
        stdout=output_handle,
        stderr=subprocess.STDOUT,
    )
    return Worker(
        opt=opt,
        tmp_path=tmp_path,
        out_path=output_handle.name,
        input_handle=input_handle,
        output_handle=output_handle,
        proc=proc,
    )


def finalize_worker(worker):
    worker.proc.wait()
    worker.output_handle.close()
    worker.input_handle.close()
    os.unlink(worker.tmp_path)
    return worker.proc.returncode


def main():
    client = connect_redis()
    try:
        if client.ping() != "PONG":
            raise RedisError("no server?")
        all_keys = client.keys("*")
        print(f"total expressions = {len(all_keys)}")

        skip = 0
        pending = []
        for opt in all_keys:
            rewrite, version = client.hmget(opt, "rewrite", "version")
            if rewrite and version == CACHE_VERSION:
                skip += 1
                continue
            pending.append(opt)

        print(f"skipping {skip} already-processed current-version expressions")
        print(f"remaining expressions = {len(pending)}")

        status = StatusPrinter(len(pending))
        running = {}
        count = 1
        completed = 0
        timed_out = 0
        failed = 0

        def reap_one():
            nonlocal completed, timed_out, failed
            pid, _ = os.wait()
            worker = running.pop(pid)
            result = finalize_worker(worker)
            if result == 124:
                timed_out += 1
                mark_timeout(worker.opt)
            elif result == 0:
                completed += 1
            else:
                failed += 1

        for opt in pending:
            if ARGS.verbose:
                status.tick()
            while len(running) >= ARGS.n:
                reap_one()
            print(f"\r\033[Ksolving {count}", end="", flush=True)
            count += 1
            worker = launch_worker(opt)
            running[worker.proc.pid] = worker

        while running:
            reap_one()

        print()
        print(f"{completed} completed worker exits")
        print(f"{timed_out} timed out worker exits")
        print(f"{failed} failed worker exits")
        print(f"{skip} skipped already-processed current-version entries")
    finally:
        client.close()


if __name__ == "__main__":
    main()

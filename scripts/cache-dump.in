import argparse
import sys

sys.path.insert(0, "@PROJECT_SOURCE_DIR@/scripts")
from minotaur_redis import RedisClient, RedisError


def usage():
    print(
        "Options:\n"
        "  -dumpall                                           dump all LHSs\n"
        "  -tofiles                                           dump all LHSs to files\n"
        "  -sort=timestamp|costdiff|reduce|cutsize|profile    sort optimizations\n"
        "  -verbose\n"
        "  -unix                                              talk to Redis using UNIX domain sockets"
    )
    raise SystemExit(-1)


def parse_ir(opt):
    return "".join(line for line in opt.splitlines(True) if not line.startswith(";"))


def as_number(value, default=0.0):
    if value in (None, ""):
        return default
    try:
        return float(value)
    except ValueError:
        return default


parser = argparse.ArgumentParser(add_help=False)
parser.add_argument("-dumpall", action="store_true")
parser.add_argument("-tofiles", action="store_true")
parser.add_argument("-redis-port", type=int, default=6379)
parser.add_argument("-sort", default="timestamp")
parser.add_argument("-verbose", action="store_true")
parser.add_argument("-unix", action="store_true")
try:
    ARGS, EXTRA = parser.parse_known_args()
except SystemExit:
    usage()

if EXTRA or ARGS.sort not in {"timestamp", "costdiff", "reduce", "cutsize", "profile"}:
    usage()

CACHE_SOCK = "@CMAKE_BINARY_DIR@/cache.sock"


def connect_redis():
    if ARGS.unix:
        return RedisClient(sock_path=CACHE_SOCK)
    return RedisClient(server=("localhost", ARGS.redis_port))


def main():
    client = connect_redis()
    try:
        if client.ping() != "PONG":
            raise RedisError("no server?")
        all_keys = client.keys("*")
        print(f"; Inspecting {len(all_keys)} Redis values")

        if ARGS.dumpall:
            print(f"; Dumping all {len(all_keys)} rewrites")
            for count, opt in enumerate(all_keys):
                entry = client.hgetall(opt)
                ir = parse_ir(opt)
                if ARGS.tofiles:
                    with open(f"dump_{count}.ll", "w", encoding="utf-8") as out:
                        out.write(ir)
                else:
                    print(ir)
                    print(f"rewrite: {entry.get('rewrite')}")
                    print(f"timestamp: {entry.get('timestamp')}")
                    print(f"profile: {entry.get('profile')}")
                    print(f"in fn: {entry.get('fn')}")
                    print("\n------------------------------------------------------")
            return

        entries = []
        noopt_count = 0
        for opt in all_keys:
            entry = client.hgetall(opt)
            rewrite = entry.get("rewrite", "")
            if rewrite == "<no-sol>":
                noopt_count += 1
                continue

            cost_after = int(as_number(entry.get("costafter"), 0))
            cost_before = int(as_number(entry.get("costbefore"), 0))
            if cost_before == 0:
                cost_before = 1
            if cost_after == 0:
                cost_after = 1

            entries.append(
                {
                    "ir": parse_ir(opt),
                    "rewrite": rewrite,
                    "costafter": cost_after,
                    "costbefore": cost_before,
                    "costdiff": cost_before - cost_after,
                    "reduce": (cost_before - cost_after * 1.0) / cost_before,
                    "timestamp": as_number(entry.get("timestamp"), 0),
                    "profile": as_number(entry.get("profile"), 0),
                    "fn": entry.get("fn", ""),
                    "cutsize": len(opt),
                }
            )

        print(f"; Discarding {noopt_count} not-optimizations leaving {len(entries)} optimizations")
        entries.sort(key=lambda entry: entry[ARGS.sort], reverse=True)

        for count, entry in enumerate(entries):
            if ARGS.tofiles:
                with open(f"dump_{count}.src.ll", "w", encoding="utf-8") as out:
                    out.write(entry["ir"])
                    out.write("\n")
            else:
                print("; opt ---------------------------------------------------")
                print(entry["ir"], end="" if entry["ir"].endswith("\n") else "\n")
                print(f"; minotaur_rewrite: {entry['rewrite']} ")
                print(f"; minotaur_cost-before: {entry['costbefore']}")
                print(f"; minotaur_cost-after: {entry['costafter']}")
                print(f"; minotaur_timestamp: {entry['timestamp']}")
                print(f"; minotaur_profile: {entry['profile']}")
                print(f"; minotaur_fn: {entry['fn']}")
    finally:
        client.close()


if __name__ == "__main__":
    main()

use warnings;
use strict;
use File::Temp;

if ($0 =~ /slice-cc$/) {
  unshift @ARGV, "@LLVM_BINARY_DIR@/bin/clang";
} elsif ($0 =~ /slice-c\+\+$/) {
  unshift @ARGV, "@LLVM_BINARY_DIR@/bin/clang++";
} else {
  die "Didn't expect slice-cc to be invoked as '$0'";
}

foreach my $arg (@ARGV) {
  if ($arg eq "-help" || $arg eq "--help") {
    print <<EOF;
Minotaur slice compiler wrapper.

Usage: slice-cc [options] <source files>
       slice-c++ [options] <source files>

This tool extracts slices from source code for analysis.

For more information, see: https://github.com/minotaur-toolkit/minotaur
EOF
    exit(-1);
  }
}

my $minotaur = 1;

sub is_compiling() {
  foreach my $arg (@ARGV) {
    return 1 if ($arg =~ /\.c$|\.cpp$|\.CC$|\.c\+\+$|\.cc$|\.cxx$|\.C$|\.c\+$/);
  }
  return 0;
}

$minotaur = 0 unless is_compiling();

if ($minotaur) {
  push @ARGV, ("-fpass-plugin=@CACHE_EXPRS_PASS@");
}

exec @ARGV;
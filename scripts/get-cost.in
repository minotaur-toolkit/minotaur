#!/bin/bash

set -e
set -o pipefail

OS="$(uname -s)"
if [[ "${OS}" == "Darwin" ]]; then
  # macOS: use the second line
  @LLVM_BINARY_DIR@/bin/clang --target=aarch64-unknown-linux-gnu -S -O2 -o - "$@" | @LLVM_BINARY_DIR@/bin/llvm-mca --iterations 1 -mtriple=aarch64-unknown-linux-gnu | grep "Total uOps" | tr ' ' '\n' | tail -1
elif [[ "${OS}" == "Linux" ]]; then
  # Linux: use the first line
  @LLVM_BINARY_DIR@/bin/clang -march=native -S -O2 -o - "$@" | @LLVM_BINARY_DIR@/bin/llvm-mca --iterations 1 -mcpu=native | grep "Total uOps" | tr ' ' '\n' | tail -1
else
  echo "Unsupported platform: ${OS}" >&2
  exit 1
fi
